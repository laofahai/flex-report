# Configuration your database connection
DATABASE_URL="file:./dev.db"

# if you are using Clerk for authentication, uncomment the following lines and replace with your actual keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<YOUR_CLERK_PUBLISHABLE_KEY>
# CLERK_SECRET_KEY=<YOUR_CLERK_SECRET_KEY>
